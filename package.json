{
  "name": "m7-cms",
  "version": "1.0.0",
  "description": "Painel CMS multi sites para clientes M7",
  "keywords": [
    "M7",
    "CMS",
    "M7 Dev"
  ],
  "author": "M7 Dev",
  "license": "ISC",
  "scripts": {
    "start:web": "pnpm --filter m7-cms-web dev",
    "start:api": "pnpm --filter m7-cms-api start:dev",
    "dev": "pnpm --filter m7-cms-web --filter m7-cms-api --parallel dev",
    "start:all": "pnpm --filter m7-cms-web --filter m7-cms-api --parallel start"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "type": "module"
}